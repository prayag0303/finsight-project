{
  "name": "finsight-backend",
  "version": "1.0.0",
  "description": "FinSight API — Node.js + Express + Prisma",
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "dev": "nodemon server.js",
    "postinstall": "prisma generate",
